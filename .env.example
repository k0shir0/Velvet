# ─── Discord ─────────────────────────────────────────────────────────────
# Bot token from the Discord Developer Portal (Bot → Reset Token).
# Leave blank to run the dashboard in "offline" mode (no bot login).
# NOTE: put your REAL token in `.env` (gitignored), never here.
TOKEN=

# Application (client) ID — used to register slash commands.
CLIENT_ID=

# The guild (server) ID where slash commands are registered (instant updates).
GUILD_ID=

# ─── Dashboard ───────────────────────────────────────────────────────────
# Port the control-panel API + WebSocket server listens on.
DASHBOARD_PORT=4317

# Password required to log into the control panel.
DASHBOARD_PASSWORD=velvet

# ─── Runtime ─────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically).
DATABASE_PATH=./data/velvet.sqlite

NODE_ENV=development
